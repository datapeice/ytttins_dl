BOT_TOKEN=
ADMIN_USERNAME=

# ─────────────────────────────────────────
# Telegram Local Bot API Server
# Получить на https://my.telegram.org → API development tools
# ─────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# ─────────────────────────────────────────
# Webhook (нужен HTTPS домен, настрой Nginx/Caddy на проброс на WEBAPP_PORT)
# ─────────────────────────────────────────
# Внешний домен (через Nginx → бот). Нужен Telegram для доступа через интернет.
WEBHOOK_HOST=h
# Внутренний адрес бота для локального telegram-bot-api (Docker-сеть)
# Не менять если не переименовывал контейнер бота
WEBHOOK_INTERNAL_HOST=http://telegram-downloader-bot:8443
WEBAPP_PORT=8443

# ─────────────────────────────────────────
# Cobalt API (локальный контейнер)
# ─────────────────────────────────────────
USE_COBALT=true
COBALT_API_URL_PUBLIC=http://YOUR_SERVER_IP:9000
COBALT_API_KEY=your_secret_cobalt_api_key
COBALT_API_NAME=HomeWorker
COBALT_VIDEO_PROXY=true
COBALT_USE_COOKIES=true
COBALT_REQUIRE_API_KEY=true

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=bot
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=botdb

# ─────────────────────────────────────────
# Прокси (опционально)
# ─────────────────────────────────────────
SOCKS_PROXY=
HTTP_PROXY=
HTTPS_PROXY=

# ─────────────────────────────────────────
# TLS Fingerprinting & Browser Impersonation
# Автоматически включено через Chrome 120 + curl-cffi
# Помогает обходить блокировки YouTube, Reddit и других сайтов
# ─────────────────────────────────────────
# CHROME_BIN=/usr/bin/google-chrome-stable (автоматически в Docker)
# PHANTOMJS_BIN=/usr/local/bin/phantomjs (автоматически в Docker)
# CURL_IMPERSONATE=chrome120 (автоматически в Docker)

# ─────────────────────────────────────────
# Прочее
# ─────────────────────────────────────────
TZ=Europe/Moscow
WHITELISTED=
COOKIES_CONTENT=

# ─────────────────────────────────────────
# AI extractor auto-fix (Groq first)
# ─────────────────────────────────────────
AI_AUTOFIX_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
