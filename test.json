5d5", "channel_id": "MS4wLjABAAAAC35opWTd4TpLHsnF2mFmAHbkrW4-Rse8wOvlTGEtG8wsmhI42uqdM8QAePWLoKA_", "uploader": "bnetanyahu", "uploader_id": "6867491921787683845", "channel_url": "https://www.tiktok.com/@MS4wLjABAAAAC35opWTd4TpLHsnF2mFmAHbkrW4-Rse8wOvlTGEtG8wsmhI42uqdM8QAePWLoKA_", "uploader_url": "https://www.tiktok.com/@bnetanyahu", "track": "original sound", "artists": ["Benjamin Netanyahu - \u05e0\u05ea\u05e0\u05d9\u05d4\u05d5"], "duration": 600, "title": "\u05d0\u05e0\u05d7\u05e0\u05d5 \u05d1\u05e2\u05d9\u05e6\u05d5\u05de\u05d4 \u05e9\u05dc \u05de\u05e2\u05e8\u05db\u05d4 \u05d2\u05d5\u05e8\u05dc\u05d9\u05ea \u05e2\u05dc \u05e7\u05d9\u05d5\u05de\u05e0\u05d5. \u05d1\u05e9\u05d1\u05d5\u05e2 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05e4\u05e2\u05dc\u05e0\u05d5 \u05d1\u05e2\u05d5\u05e6\u05de\u05d4, \u05d1...", "description": "\u05d0\u05e0\u05d7\u05e0\u05d5 \u05d1\u05e2\u05d9\u05e6\u05d5\u05de\u05d4 \u05e9\u05dc \u05de\u05e2\u05e8\u05db\u05d4 \u05d2\u05d5\u05e8\u05dc\u05d9\u05ea \u05e2\u05dc \u05e7\u05d9\u05d5\u05de\u05e0\u05d5. \u05d1\u05e9\u05d1\u05d5\u05e2 \u05d4\u05d0\u05d7\u05e8\u05d5\u05df \u05e4\u05e2\u05dc\u05e0\u05d5 \u05d1\u05e2\u05d5\u05e6\u05de\u05d4, \u05d1\u05d9\u05d5\u05d6\u05de\u05d4 \u05d5\u05d1\u05e0\u05d7\u05d9\u05e9\u05d5\u05ea \u05de\u05d5\u05dc \u05d0\u05d5\u05d9\u05d1\u05d9\u05e0\u05d5 - \u05d5\u05e0\u05de\u05e9\u05d9\u05da \u05dc\u05e4\u05e2\u05d5\u05dc \u05d1\u05db\u05dc \u05d4\u05db\u05d5\u05d7, \u05e2\u05d3 \u05dc\u05d4\u05e9\u05d2\u05ea \u05db\u05dc \u05de\u05d8\u05e8\u05d5\u05ea\u05d9\u05e0\u05d5. \u05d0\u05e0\u05d9 \u05de\u05e6\u05d3\u05d9\u05e2 \u05dc\u05d8\u05d9\u05d9\u05e1\u05d9\u05e0\u05d5, \u05dc\u05dc\u05d5\u05d7\u05de\u05d9\u05e0\u05d5, \u05dc\u05e6\u05d5\u05d5\u05ea\u05d9 \u05d4\u05e7\u05e8\u05e7\u05e2, \u05dc\u05db\u05d5\u05d7\u05d5\u05ea \u05d4\u05d1\u05d9\u05d8\u05d7\u05d5\u05df \u05d5\u05d4\u05d4\u05e6\u05dc\u05d4, \u05d5\u05dc\u05db\u05dd - \u05d0\u05d6\u05e8\u05d7\u05d9 \u05d9\u05e9\u05e8\u05d0\u05dc - \u05e2\u05dc \u05d4\u05e8\u05d5\u05d7 \u05d4\u05d0\u05d9\u05ea\u05e0\u05d4, \u05d4\u05d0\u05d7\u05e8\u05d9\u05d5\u05ea \u05d5\u05d4\u05e2\u05de\u05d9\u05d3\u05d4 \u05d4\u05d0\u05de\u05d9\u05e6\u05d4. \u05d9\u05d7\u05d3 \u05e9\u05d9\u05e0\u05d9\u05e0\u05d5 \u05d0\u05ea \u05e4\u05e0\u05d9 \u05d4\u05de\u05d6\u05e8\u05d7 \u05d4\u05ea\u05d9\u05db\u05d5\u05df. \u05d9\u05d7\u05d3 \u05e0\u05de\u05e9\u05d9\u05da \u05dc\u05d4\u05d9\u05dc\u05d7\u05dd. \u05d9\u05d7\u05d3 \u05e0\u05e9\u05d0\u05d2 \u05db\u05d0\u05e8\u05d9. \u05d5\u05d1\u05e2\u05d6\u05e8\u05ea \u05d4\u05e9\u05dd - \u05d9\u05d7\u05d3 \u05e0\u05d1\u05d8\u05d9\u05d7 \u05d0\u05ea \u05e0\u05e6\u05d7 \u05d9\u05e9\u05e8\u05d0\u05dc. \u05e6\u05e4\u05d5 \u05d1\u05d3\u05d1\u05e8\u05d9\u05dd \u05d4\u05de\u05dc\u05d0\u05d9\u05dd >>", "timestamp": 1772915448, "view_count": 413400, "like_count": 31300, "repost_count": 10100, "comment_count": 2258, "save_count": 2232, "thumbnails": [{"id": "dynamicCover", "url": "https://p16-common-sign.tiktokcdn-eu.com/tos-alisg-p-0037/ogKDXRGeLdkdWLyRqj2sAC4IYK6ggoEeATRvfI~tplv-tiktokx-origin.image?dr=10395&x-expires=1773158400&x-signature=ghR9UVT2bCasSzrI5cQXdkdGVUc%3D&t=4d5b0474&ps=13740610&shp=81f88b70&shcp=43f4a2f9&idc=no1a", "preference": -2}, {"id": "cover", "url": "https://p16-common-sign.tiktokcdn-eu.com/tos-alisg-p-0037/oUiRDEgeIMpBu5EwIBsEJUFKXrL2iBfIliAvru~tplv-tiktokx-origin.image?dr=10395&x-expires=1773158400&x-signature=QprhwDtM3hch6lHQoZPyRvxWyek%3D&t=4d5b0474&ps=13740610&shp=81f88b70&shcp=43f4a2f9&idc=no1a", "preference": -1}, {"id": "originCover", "url": "https://p16-common-sign.tiktokcdn-eu.com/tos-alisg-p-0037/oYJsRILSpIUzE4BliBrF5CrEIeDAMaAuugfQ0X~tplv-tiktokx-origin.image?dr=10395&x-expires=1773158400&x-signature=AayBt9JRahO0EDzjTNgDthKKtF4%3D&t=4d5b0474&ps=13740610&shp=81f88b70&shcp=43f4a2f9&idc=no1a", "preference": -1}], "original_url": "https://vt.tiktok.com/ZNRu2WWyE/", "webpage_url": "https://www.tiktok.com/@bnetanyahu/video/7614613832740195602?_r=1&_t=ZN-94WQMvdb4gU", "webpage_url_basename