# ── ytttins-dl Java bot — environment variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Spring Boot also reads these via application.yml variable substitution.

# ─── REQUIRED ─────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_from_BotFather
ADMIN_USERNAME=your_telegram_username

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL (production)
# DATABASE_URL=jdbc:postgresql://localhost:5432/botdb
# POSTGRES_USER=bot
# POSTGRES_PASSWORD=change_me_strong_password
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# H2 (default, no setup required)
# DATABASE_URL=jdbc:h2:file:./data/botdb;AUTO_SERVER=TRUE

# ─── OPTIONAL: Webhook ────────────────────────────────────────────────────────
# Leave blank to use long-polling mode (recommended for development)
WEBHOOK_HOST=https://bot.example.com
WEBHOOK_INTERNAL_HOST=http://bot-container:8443
WEBAPP_PORT=8443

# ─── OPTIONAL: Local Telegram Bot API ────────────────────────────────────────
# Enables uploading files larger than 50 MB
# TELEGRAM_API_URL=http://telegram-bot-api:8081

# ─── OPTIONAL: Cobalt API (fallback downloader) ──────────────────────────────
USE_COBALT=false
COBALT_API_URL_PUBLIC=http://YOUR_SERVER_IP:9000
COBALT_API_KEY=your_secret_cobalt_api_key

# ─── OPTIONAL: Proxy ─────────────────────────────────────────────────────────
# SOCKS_PROXY=socks5h://user:pass@proxy:1080
# HTTP_PROXY=http://proxy:8080

# ─── OPTIONAL: Whitelist ─────────────────────────────────────────────────────
# Semicolon-separated usernames; leave blank to open the bot to everyone
# WHITELISTED=alice;bob;charlie

# ─── OPTIONAL: YouTube Cookies ───────────────────────────────────────────────
# Paste full Netscape-format cookies.txt content (escape newlines as \n)
# COOKIES_CONTENT=

# ─── OTHER ───────────────────────────────────────────────────────────────────
TZ=Europe/Moscow
H2_CONSOLE_ENABLED=false
